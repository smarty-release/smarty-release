{
  "name": "smarty-release",
  "version": "0.0.0",
  "description": "A smarter `npm publish`",
  "keywords": [
    "release"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/smarty-release/smarty-release.git"
  },
  "funding": "https://www.lujiahao.com/sponsor",
  "license": "MIT",
  "author": "ajiho",
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.mts",
        "./*"
      ]
    }
  },
  "bin": {
    "smarty-release": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "templates",
    "schema"
  ],
  "scripts": {
    "lint": "eslint . --cache",
    "lint:fix": "pnpm lint --fix",
    "build": "tsdown",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs --open",
    "docs:preview": "vitepress preview docs",
    "format": "prettier --cache --write .",
    "release": "pnpm build && node dist/cli.mjs",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "ansis": "^4.2.0",
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "hosted-git-info": "^9.0.2",
    "lilconfig": "^3.1.3",
    "listr2": "^10.2.1",
    "mri": "^1.2.0",
    "nanospinner": "^1.2.2",
    "package-manager-detector": "^1.6.0",
    "pkg-types": "^2.3.1",
    "semver": "^7.7.4",
    "smol-toml": "^1.6.1",
    "tinyexec": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/hosted-git-info": "^3.0.5",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "defu": "^6.1.7",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.10",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "valibot": "^1.3.1",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-mermaid-renderer": "^1.1.23",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitepress-plugin-tabs": "^0.9.0",
    "vue": "^3.5.33"
  },
  "peerDependencies": {
    "jiti": "*"
  },
  "peerDependenciesMeta": {
    "jiti": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "git-cliff-darwin-arm64": "2.12.0",
    "git-cliff-darwin-x64": "2.12.0",
    "git-cliff-linux-arm64": "2.12.0",
    "git-cliff-linux-x64": "2.12.0",
    "git-cliff-windows-arm64": "2.12.0",
    "git-cliff-windows-x64": "2.12.0"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "^22.18.0 || >=24.0.0"
  },
  "publishConfig": {
    "tag": "latest"
  }
}
