{
  "name": "smarty-release",
  "version": "0.0.0",
  "description": "A smart and lightweight CLI for automating project releases.",
  "keywords": [
    "release"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/smarty-release/smarty-release.git"
  },
  "funding": "https://www.lujiahao.com/sponsor",
  "license": "MIT",
  "author": "ajiho",
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "index.js",
  "bin": {
    "smarty-release": "dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "cnt": "node a.js",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "prettier --cache --write .",
    "release": "node dist/cli.mjs"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "cac": "^7.0.0",
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "git-cliff": "^2.12.0",
    "hosted-git-info": "^9.0.2",
    "lilconfig": "^3.1.3",
    "ora": "^9.3.0",
    "pkg-types": "^2.3.0",
    "semver": "^7.7.4",
    "smol-toml": "^1.6.1",
    "tinyexec": "^1.1.1"
  },
  "devDependencies": {
    "@types/hosted-git-info": "^3.0.5",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "defu": "^6.1.7",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.8",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "vitepress": "^2.0.0-alpha.17"
  },
  "peerDependencies": {
    "jiti": "*"
  },
  "peerDependenciesMeta": {
    "jiti": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.18.0 || >=24.0.0"
  },
  "files": [
    "dist",
    "templates"
  ]
}
