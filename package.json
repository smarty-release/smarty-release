{
  "name": "release-pls",
  "version": "0.0.0",
  "description": "A lightweight, generic release CLI with steps and hooks.",
  "keywords": [
    "release-please",
    "release-pls"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/release-pls/release-pls.git"
  },
  "funding": "https://www.lujiahao.com/sponsor",
  "license": "MIT",
  "author": "ajiho",
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "index.js",
  "bin": {
    "release-pls": "dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "cnt": "node a.js",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "prettier --cache --write .",
    "release": "node dist/cli.mjs"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@npmcli/package-json": "^7.0.5",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "execa": "^9.6.1",
    "git-cliff": "^2.12.0",
    "hosted-git-info": "^9.0.2",
    "lilconfig": "^3.1.3",
    "ora": "^9.3.0",
    "semver": "^7.7.4",
    "smol-toml": "^1.6.1",
    "tempy": "^3.2.0"
  },
  "devDependencies": {
    "@types/hosted-git-info": "^3.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/npmcli__package-json": "^4.0.4",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.7.1",
    "fs-extra": "^11.3.4",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "vitepress": "^2.0.0-alpha.17"
  },
  "peerDependencies": {
    "jiti": "*"
  },
  "peerDependenciesMeta": {
    "jiti": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.18.0 || >=24.0.0"
  }
}
