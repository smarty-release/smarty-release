{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "changelog": {
      "oneOf": [
        { "type": "boolean", "const": false },
        { "$ref": "./changelog.json" }
      ]
    },
    "requireBranch": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        },
        {
          "type": "string",
          "format": "regex"
        },
        { "type": "boolean", "const": false }
      ]
    },
    "commitMessage": {
      "type": "string"
    },
    "commitArgs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tagName": {
      "type": "string"
    }
  }
}
