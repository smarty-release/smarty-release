{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^(before|after):(init|selectVersion|bump|release|selectTag|changelog|git(\\.add|\\.commit|\\.tag|\\.push)?)$": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    }
  }
}
